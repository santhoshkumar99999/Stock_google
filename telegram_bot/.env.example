# 1. Get from https://my.telegram.org (Log in -> API development tools)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# 2. Get from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# 3. Get your target Chat ID (Use @userinfobot or forward a message to @JsonDumpBot)
# Ensure your bot is added to this target chat or channel
TARGET_CHAT=your_target_chat_id_here
